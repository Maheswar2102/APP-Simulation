# Anthropic API key — get it from https://console.anthropic.com/
# GitHub Personal Access Token — no separate billing needed, works with GitHub Copilot.
# Create one at https://github.com/settings/tokens  (no special scopes required for GitHub Models)
GITHUB_TOKEN=your_github_personal_access_token_here
MODEL=gpt-4o-mini

# Target site
APP_URL=http://dev1803.dev.e2open.com:9880/Main.action

# Excel input source
# The Excel file should contain headers: app_username, app_password, customer_name, config_number
EXCEL_PATH=input.xlsx
# Leave blank to use the first sheet
EXCEL_SHEET=
# 1 means first data row below header
EXCEL_ROW_INDEX=1
KEEP_OPEN=true
EXCEL_CREDENTIALS_SHEET=Credentials
EXCEL_MENU_SHEET=Master data
EXCEL_HIERARCHY_SHEET=Hierarchy
